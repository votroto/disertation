@article{nie.yang.ea:saddle,
  author   = {Nie, Jiawang and Yang, Zi and Zhou, Guangming},
  title    = {The Saddle Point Problem of Polynomials},
  journal  = {Foundations of Computational Mathematics},
  year     = {2022},
  month    = {Aug},
  day      = {01},
  volume   = {22},
  number   = {4},
  pages    = {1133-1169},
  abstract = {This paper studies the saddle point problem of
              polynomials. We give an algorithm for computing saddle
              points. It is based on solving Lasserre's hierarchy of
              semidefinite relaxations. Under some genericity assumptions
              on defining polynomials, we show that: (i) if there exists
              a saddle point, our algorithm can get one by solving a
              finite hierarchy of Lasserre-type semidefinite relaxations;
              (ii) if there is no saddle point, our algorithm can detect
              its nonexistence.},
  issn     = {1615-3383},
  doi      = {10.1007/s10208-021-09526-8},
  url      = {https://doi.org/10.1007/s10208-021-09526-8}
}

