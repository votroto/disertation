@Article{Golman2009,
author={Golman, Russell
and Page, Scott E.},
title={General Blotto: games of allocative strategic mismatch},
journal={Public Choice},
year={2009},
month={Mar},
day={01},
volume={138},
number={3},
pages={279-299},
abstract={The Colonel Blotto game captures strategic situations in which players attempt to mismatch an opponent's action. We extend Colonel Blotto to a class of General Blotto games that allow for more general payoffs and externalities between fronts. These extensions make Blotto applicable to a variety of real-world problems. We find that like Colonel Blotto, most General Blotto games do not have pure strategy equilibria. Using a replicator dynamics learning model, we show that General Blotto may have more predictable dynamics than the original Blotto game. Thus, adding realistic structure to Colonel Blotto may, paradoxically, make it less complex.},
issn={1573-7101},
doi={10.1007/s11127-008-9359-x},
url={https://doi.org/10.1007/s11127-008-9359-x}
}

