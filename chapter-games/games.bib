@article{roberson.colonel,
	title = {The Colonel Blotto game},
	volume = {29},
	issn = {1432-0479},
	url = {https://doi.org/10.1007/s00199-005-0071-5},
	doi = {10.1007/s00199-005-0071-5},
	abstract = {In the Colonel Blotto game, two players simultaneously distribute forces across n battlefields. Within each battlefield, the player that allocates the higher level of force wins. The payoff of the game is the proportion of wins on the individual battlefields. An equilibrium of the Colonel Blotto game is a pair of n-variate distributions. This paper characterizes the unique equilibrium payoffs for all (symmetric and asymmetric) configurations of the players’ aggregate levels of force, characterizes the complete set of equilibrium univariate marginal distributions for most of these configurations, and constructs entirely new and novel equilibrium n-variate distributions.},
	pages = {1--24},
	number = {1},
	journaltitle = {Economic Theory},
	shortjournal = {Economic Theory},
	author = {Roberson, Brian},
	date = {2006-09-01},
}
@article{Kvasov.colonel,
title = {Contests with limited resources},
journal = {Journal of Economic Theory},
volume = {136},
number = {1},
pages = {738-748},
year = {2007},
issn = {0022-0531},
doi = {https://doi.org/10.1016/j.jet.2006.06.007},
url = {https://www.sciencedirect.com/science/article/pii/S0022053106001244},
author = {Dmitriy Kvasov},
keywords = {Contests, Budget restrictions, Blotto game, All-pay auctions},
abstract = {Many interesting phenomena (electoral competition, R&D races, lobbying) are instances of multiple simultaneous contests with unconditional commitment of limited resources. Specifically, the following game is analyzed. Two players compete in a number of simultaneous contests. The players have limited resources (budgets) and must decide how to allocate these to the different contests. In each contest the player who expends more resources than his adversary wins a corresponding prize. Mixed-strategy equilibria are characterized in the case of identical values and budgets and the connections with the classical Blotto game are analyzed.}
}


